{
  "manifest": [
    {
      "name": "footer",
      "url": "/components/footer.js",
      "cssUrl": "/styles/acme/footer.1.0.0.css"
    },
    {
      "name": "header",
      "url": "/components/header.js",
      "cssUrl": "/styles/acme/header.1.0.0.css"
    },
    {
      "name": "hero",
      "url": "/components/hero.js",
      "cssUrl": "/styles/acme/hero.1.0.0.css"
    },
    {
      "name": "newsletter",
      "url": "/components/newsletter.js",
      "cssUrl": "/styles/acme/newsletter.1.0.0.css"
    },
    {
      "name": "pricing-card",
      "url": "/components/pricing-card.js"
    },
    {
      "name": "pricing-cards",
      "url": "/components/pricing-cards.js",
      "cssUrl": "/styles/acme/pricing-cards.1.0.0.css"
    },
    {
      "name": "testimonial",
      "url": "/components/testimonial.js",
      "cssUrl": "/styles/acme/testimonial.1.0.0.css"
    }
  ],
  "content": {
    "hero": {
      "template": "<div class=\"hero-inner\"><h1 class=\"hero-heading\">{{ headingText }}</h1><p class=\"hero-subheading\">{{ subheadingText }}</p><a href=\"#\" class=\"hero-button\">{{ buttonText }}</a></div>",
      "buttonText": "Get started",
      "headingText": "Welcome to acme",
      "subheadingText": "The best products for your business",
      "wrapper": { "tag": "section", "classPrefix": "hero" },
      "richTextFields": ["headingText", "buttonText", "subheadingText"]
    },
    "footer": {
      "template": "<div class=\"footer-inner\"><span class=\"footer-text\">{{ footerText }}</span></div>",
      "footerText": "© Acme Corp",
      "wrapper": { "tag": "footer", "classPrefix": "footer" }
    },

    "header": {
      "template": "<div class=\"header-logo\">{{ logoText }}</div><nav class=\"header-nav\"><a href=\"#\">Home</a><a href=\"#\">About</a><a href=\"#\">Services</a><a href=\"#\">Contact</a></nav><a href=\"#\" class=\"header-cta\">{{ ctaText }}</a>",
      "logoText": "Acme Corp",
      "ctaText": "Sign In",
      "wrapper": { "tag": "header", "classPrefix": "header" }
    },

    "newsletter": {
      "template": "<h2 class=\"newsletter-heading\">{{ newsHeading }}</h2><p class=\"newsletter-subheading\">Get the best deals first</p><div class=\"newsletter-form\"><input type=\"email\" class=\"newsletter-input\" placeholder=\"Enter your email\" /><button class=\"newsletter-button\">Subscribe</button></div>",
      "newsHeading": "Subscribe to Acme News",
      "wrapper": {
        "tag": "div",
        "classPrefix": "newsletter",
        "baseClass": "newsletter-inner"
      }
    },

    "pricing-card": {
      "template": "<img src=\"{{ image }}\" alt=\"{{ title }}\" class=\"pricing-card-image\" /><h3 class=\"pricing-card-title\">{{ title }}</h3><p class=\"pricing-card-price\">{{ price }}</p><p class=\"pricing-card-desc\">{{ desc }}</p><button class=\"pricing-card-button\">{{ buttonText }}</button>",
      "buttonText": "SERVER TEST",
      "wrapper": { "tag": "div", "baseClass": "pricing-card" }
    },

    "pricing-cards": {
      "wrapper": { "tag": "div", "baseClass": "pricing-cards pricing-grid-3" },
      "cards": [
        {
          "title": "Starter",
          "price": "$19/mo",
          "desc": "Perfect for individuals just getting started.",
          "image": "https://picsum.photos/seed/starter/280/160",
          "buttonText": "Choose Plan"
        },
        {
          "title": "Pro",
          "price": "$49/mo",
          "desc": "For growing teams that need more power.",
          "image": "https://picsum.photos/seed/pro/280/160",
          "buttonText": "Choose Plan"
        },
        {
          "title": "Enterprise",
          "price": "$99/mo",
          "desc": "Advanced features for large organizations.",
          "image": "https://picsum.photos/seed/enterprise/280/160",
          "buttonText": "Choose Plan"
        }
      ]
    },
    "testimonial": {
      "template": "<p class=\"testimonial-quote\">{{ quote }}</p><span class=\"testimonial-author\">- Jane</span>",
      "quote": "Great product!",
      "wrapper": {
        "tag": "div",
        "classPrefix": "testimonial",
        "baseClass": "testimonial"
      }
    }
  }
}
